# Composer (legacy app at repo root)
/vendor/

# Environment / local overrides
.env
.env.*
!.env.example

# User-uploaded inspection photos (runtime; keep dir with .gitkeep if you track empty folder)
/site_inspection_photos/*
!/site_inspection_photos/.gitkeep

# Logs & caches
*.log
.phpunit.result.cache

# Local secrets (copy inc/backend/db_cred_constants.example.php → db_cred_constants.php)
/inc/backend/db_cred_constants.php

# Python virtualenv (often created beside the repo for tooling)
.venv/
venv/
__pycache__/
*.pyc

# SQLite (e.g. Laravel local dev)
*.sqlite
*.sqlite-journal

# Laravel app (if you add `laravel-app/` again)
/laravel-app/vendor/
/laravel-app/node_modules/
/laravel-app/.env
/laravel-app/.env.*
!/laravel-app/.env.example
/laravel-app/public/build
/laravel-app/public/hot
/laravel-app/public/storage
/laravel-app/storage/*.key
/laravel-app/storage/logs/
/laravel-app/storage/framework/cache/data/
/laravel-app/storage/framework/sessions/
/laravel-app/storage/framework/views/
/laravel-app/bootstrap/cache/*.php
!/laravel-app/bootstrap/cache/.gitignore

# IDE / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
